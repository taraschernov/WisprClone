# Groq API Configuration
# Get your free key at: https://console.groq.com/keys
GROQ_API_KEY=

# Hotkey Configuration
# Examples: 'alt', 'ctrl+space', 'alt+space', 'ctrl+alt+space', 'f8', 'right ctrl'
HOTKEY=ctrl+alt+space

# Application Settings
LANGUAGE=ru # Language fallback for whisper (can be omitted for auto-detect)

# Notion Integration (Optional)
NOTION_API_KEY=
NOTION_DATABASE_ID=
